# Google OAuth credentials for Calendar integration (Phase 11).
# Create via: https://console.cloud.google.com > APIs & Services > Credentials
# OAuth 2.0 Client ID of type "Desktop app".
#
# These are injected at BUILD TIME via electron-vite `define` and replaced as
# literal string constants in the compiled bundle. They are NEVER persisted
# to disk at runtime. The client_secret is non-confidential per Google's
# Desktop-app OAuth model but must not be committed.
#
# Copy this file to .env.local and fill in real values before `npm run build`.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mobile PWA OAuth (Phase 12). Web-type OAuth client in the SAME GCP project as GOOGLE_CLIENT_ID (Desktop client, Phase 11).
GOOGLE_WEB_CLIENT_ID=your-web-client-id-from-gcp.apps.googleusercontent.com
